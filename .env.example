# FarmXpert Environment Configuration
# Copy this file to .env and fill in your values

# Database Connection (PostgreSQL)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://farmxpert_user:YOUR_SECURE_PASSWORD@localhost:5432/farmxpert_db

# Alternative: Individual database settings (if not using DATABASE_URL)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=farmxpert_user
# PGPASSWORD=YOUR_SECURE_PASSWORD
# PGDATABASE=farmxpert_db

# Server Configuration
PORT=5000
NODE_ENV=production

# CORS Configuration (Optional - for production security)
# Set this to your domain to restrict cross-origin requests
# Leave empty or remove to allow all origins (less secure)
# Examples: https://yourdomain.com or http://your-vps-ip:5000
# CORS_ORIGIN=https://yourdomain.com

# Google Gemini AI API Key (Optional - for AI Advisor feature)
# Get your key from: https://aistudio.google.com/app/apikey
API_KEY=your_gemini_api_key_here

# Authentication Configuration
# JWT secret key - use a long random string (32+ characters recommended)
JWT_SECRET=your-secure-random-secret-key-change-this-in-production

# Application URL (used in email links)
# Set this to your server's public URL
APP_URL=http://your-server-ip:5000

# Gmail Configuration (for sending verification and password reset emails)
# 1. Enable 2-Step Verification in your Google Account
# 2. Go to Security > App passwords > Create new app password
# 3. Use the 16-character password below
GMAIL_USER=farmxpertfx@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password
